rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - caption: string (required)
    //   - imageUrl: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: site
    // Fields:
    //   - heroTitle: string
    //   - heroSubtitle: string
    //   - heroDescription: string
    //   - aboutText: string
    //   - contactEmail: string
    //   - footerText: string
    //   - profileName: string
    //   - profileTitle: string
    //   - profileImage: string
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "rajuchacchu30@gmail.com" || 
         request.auth.token.email == "mahfujul848@gmail.com");
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.caption is string && data.caption.size() > 0 && data.caption.size() < 2000 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.heroTitle is string && data.heroTitle.size() < 200 &&
             data.heroSubtitle is string && data.heroSubtitle.size() < 200 &&
             data.contactEmail is string && data.contactEmail.size() < 200;
    }

    function isValidService(data) {
      return data.title is string && data.title.size() > 0 &&
             data.description is string && data.description.size() > 0 &&
             data.icon is string;
    }

    // Rules
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidPost(request.resource.data);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidService(request.resource.data);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
