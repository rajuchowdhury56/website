{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A portfolio project or blog post",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the post" },
        "caption": { "type": "string", "description": "Short description or caption" },
        "imageUrl": { "type": "string", "description": "URL of the project image" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "caption", "imageUrl", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name" }
      },
      "required": ["title", "description", "icon"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration and text",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "aboutText": { "type": "string" },
        "contactEmail": { "type": "string" },
        "footerText": { "type": "string" },
        "profileName": { "type": "string" },
        "profileTitle": { "type": "string" },
        "profileImage": { "type": "string" }
      },
      "required": ["heroTitle", "heroSubtitle", "aboutText", "contactEmail"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of portfolio posts"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services offered"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Global site configuration document"
    }
  }
}
